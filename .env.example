# ── Required ─────────────────────────────────────────────────────────────────
# Password for manager (admin) mode. Mutating admin endpoints return 500 until set.
ADMIN_TOKEN=change-this-admin-token

# ── Optional ─────────────────────────────────────────────────────────────────
# Enables agent login mode. Omit to disable agent accounts (view-only + admin still work).
# AGENT_PASSWORD=change-this-agent-password

# Persistent database (Turso / libSQL). If unset, falls back to a LOCAL file
# (file:./data.db) — fine for local dev, but on hosts with ephemeral disk
# (e.g. Render) the data resets on every restart/redeploy. For production, create
# a free Turso database and set both of these:
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# HTTP port. Defaults to 5000.
# PORT=5000
